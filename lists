scores = [85,92,78,95,61,78]
print(scores)
print(scores[0])
print(scores[-1])

print(scores[1:3]) #slicing the list from index 1 to index 2 (3 is exclusive)

scores.append(88)#adds 88 to the end of the list
print(scores)
scores.insert(0, 100)#adds 100 at index 0, shifting the rest of the elements to the right
print(scores)

scores.remove(78)#removes the first occurrence of 78 from the list
print(scores)

last = scores.pop()#removes and returns the last element of the list
print(last)

scores.sort() #ascending order(default)
print(scores)

scores.sort(reverse=True) #descending order
print(scores)

if 92 in scores:#checks if 92 is in the list of scores
    print("92 is in the list")

scores[1] = 96 #updates the value at index 1 to 96
print(scores)

for score in scores:#iterating through the list and printing each score in simple english its like saying for each score in the list of scores, print the score
    print(f"Score: {score}")